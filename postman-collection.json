    {
      "name": "Playlists - CRUD",
      "item": [
        {
          "name": "Create Playlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Awesome Playlist\",\n  \"userId\": \"replace-with-user-id\",\n  \"privacity\": \"public\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/playlists",
              "host": ["{{baseUrl}}"],
              "path": ["api", "playlists"]
            }
          },
          "response": []
