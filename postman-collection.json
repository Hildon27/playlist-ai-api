        {
          "name": "Get Playlist by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/playlists/:playlistId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "playlists", ":playlistId"],
              "variable": [
