    {
      "name": "Follow Requests",
      "item": [
        {
          "name": "Request to Follow User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"followerId\": \"{{userId}}\",\n  \"followedUserEmail\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/follow-requests/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follow-requests", "register"]
