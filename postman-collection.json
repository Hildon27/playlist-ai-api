              "host": ["{{baseUrl}}"],
              "path": ["api", "playlists", ":playlistId"],
              "query": [
                {
                  "key": "includeMusics",
                  "value": "true",
                  "description": "Include musics in response"
                }
              ],
              "variable": [
                {
                  "key": "playlistId",
                  "value": "replace-with-playlist-id",
                  "description": "Playlist ID to retrieve"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Playlist",
          "request": {
            "method": "PUT",
