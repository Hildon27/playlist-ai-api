{
  "info": {
    "name": "Playlist AI API",
    "description": "Coleção organizada para testar os endpoints da Playlist AI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Endpoints de verificação de saúde da API",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "description": "Endpoints de gerenciamento de usuários",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\",\n  \"privacity\": \"PUBLIC\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane.smith@example.com\",\n  \"privacity\": \"PRIVATE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Test Validation - Missing Fields",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          },
          "response": []
        },
        {
          "name": "Test Validation - Invalid Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"invalid-email\",\n  \"password\": \"password123\",\n  \"privacity\": \"PUBLIC\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          },
          "response": []
        },
        {
          "name": "Test Validation - Short Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"123\",\n  \"privacity\": \"PUBLIC\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Follow Requests",
      "description": "Endpoints para solicitações de seguir usuários",
      "item": [
        {
          "name": "Request to Follow User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"followerId\": \"{{userId}}\",\n  \"followedUserEmail\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/follow-requests/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follow-requests", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Find All Follow Requests by Follower ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/follow-requests/by-follower/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follow-requests", "by-follower", "{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Find All Follow Requests by Followed ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/follow-requests/by-followed/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follow-requests", "by-followed", "{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Follow Request",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"followerId\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/follow-requests/{{followRequestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follow-requests", "{{followRequestId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Process Follow Request (Approve/Reject)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"followedId\": \"{{userId}}\",\n  \"action\": \"accept\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/follow-requests/{{followRequestId}}/process",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "follow-requests",
                "{{followRequestId}}",
                "process"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Follows",
      "description": "Endpoints para gerenciamento de seguidores",
      "item": [
        {
          "name": "Find All User Followers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/follows/{{userId}}/followers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follows", "{{userId}}", "followers"]
            }
          },
          "response": []
        },
        {
          "name": "Unfollow User by Follow ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/follows/{{followId}}/unfollow",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follows", "{{followId}}", "unfollow"]
            }
          },
          "response": []
        },
        {
          "name": "Remove Follower by Follow ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/follows/{{followId}}/remove",
              "host": ["{{baseUrl}}"],
              "path": ["api", "follows", "{{followId}}", "remove"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": { "type": "text/javascript", "exec": [""] }
    },
    {
      "listen": "test",
      "script": { "type": "text/javascript", "exec": [""] }
    }
  ]
}
